# =============================================================================
# HQ Worker — local development
#
# Copy to .env and fill in the values, then:
#   npm run dev
# =============================================================================

# ── Master Supabase (control-plane database) ─────────────────
# A dedicated Supabase project that stores hosted_users, hosted_workspaces,
# sandbox_events, and idempotency_keys.
# Run apps/worker/db/master_schema.sql in the SQL editor to set it up.
MASTER_SUPABASE_URL=https://xxxxx.supabase.co
MASTER_SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── Supabase Management API ─────────────────────────────────
# Used to create per-tenant Supabase projects on signup.
# Token: https://supabase.com/dashboard/account/tokens
# Org ID: the UUID in your org settings URL
SUPABASE_MANAGEMENT_API_TOKEN=sbp_...
SUPABASE_ORG_ID=
SUPABASE_REGION=us-east-1

# ── Stripe ───────────────────────────────────────────────────
# Use test mode keys. For the webhook secret, run:
#   stripe listen --forward-to localhost:3001/webhooks/stripe
# and copy the whsec_... value it prints.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ── E2B (sandbox runtime) ───────────────────────────────────
# Each workspace gets a dedicated E2B sandbox running the gateway.
# Get your key from https://e2b.dev/dashboard
E2B_API_KEY=e2b_...
# E2B_TEMPLATE_NAME=yourhq-gateway  # optional, defaults to yourhq-gateway

# ── Resend (transactional email) ────────────────────────────
# https://resend.com — used for provisioning-complete and payment-failed emails.
RESEND_API_KEY=re_...
# EMAIL_FROM=HQ <noreply@yourhq.ai>  # optional, has a default

# ── Internal auth ────────────────────────────────────────────
# Shared secret between the UI and the worker.
# Generate with: openssl rand -hex 32
WORKER_INTERNAL_TOKEN=

# Encrypts tenant secrets (service role keys, DB passwords, VNC passwords)
# before storing in the master database.
# Generate with: openssl rand -base64 32
HOSTED_SECRETS_KEY=

# ── Public URL ───────────────────────────────────────────────
# Where the UI is reachable. Used for auth redirects and email links.
PUBLIC_SITE_URL=http://localhost:3000

# ── Optional ─────────────────────────────────────────────────
# PORT=3001  # worker listen port, defaults to 3001
