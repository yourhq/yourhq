# Supabase (get from supabase.com > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Firebase Admin (service account JSON, base64-encoded)
# Generate: base64 -i service-account.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Firebase project ID (optional, can be read from service account)
FIREBASE_PROJECT_ID=your-firebase-project-id

# GitHub token (for GitHub integration) - generate from GitHub Developer Settings > Personal Access Tokens
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=