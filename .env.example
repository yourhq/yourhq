# =============================================================================
# HQ — env file for the docker-compose stack.
#
# Copy to .env, fill in the values, then `docker compose up -d`.
# The install.sh script can do this interactively for you.
# =============================================================================

# ── Supabase ─────────────────────────────────────────────────
# Leave empty. The UI onboards the user in the browser and writes
# creds to a shared volume; the gateway reads from there automatically.
#
# Only set these if you want an env-level override (e.g. a gateway
# that must always point at a specific project regardless of what
# the UI sets). Env values take precedence over the registry.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Gateway identity ─────────────────────────────────────────
# Unique per gateway within a Supabase project. Use different values when
# running multiple gateways against the same Supabase (e.g. "laptop",
# "mac-mini", "vps-eu").
GATEWAY_ID=default
GATEWAY_LABEL=Primary gateway

# Compose project name — namespaces volumes and containers. Change if you
# run multiple gateway stacks on the same host.
COMPOSE_PROJECT=yourhq

# Workspace slug — must match the slug you set in the HQ UI
# setup wizard. Agent branches are named "${WORKSPACE_SLUG}/${agent_slug}".
WORKSPACE_SLUG=my-workspace

# ── Networking (set by install.sh based on the host's network mode) ──
# NETWORKING_MODE drives HOST_REACHABLE_URL and the *_HOST_PORT bindings.
# Tailscale + public HTTPS are HOST-level concerns; HQ containers never
# join a tailnet or manage TLS themselves.
#
#   local      = HQ reachable on this machine only (http://localhost)
#   tailscale  = Tailscale installed on the host; reachable at <host-ts-ip>
#   public     = host-level reverse proxy + TLS (e.g. Caddy on the host)
NETWORKING_MODE=local
HOST_REACHABLE_URL=http://localhost

# Host port bindings. Installer sets these automatically based on mode.
#   local     → 127.0.0.1 (loopback only; safe default)
#   tailscale → 0.0.0.0 (tailnet and localhost only — no public exposure
#              unless you ALSO open the VPS's firewall ports, which you
#              generally won't because the host's Tailscale interface is
#              the whole point)
#   public    → 0.0.0.0 behind a host-level reverse proxy
UI_HOST_PORT=127.0.0.1:3000
NOVNC_HOST_PORT=127.0.0.1:6901
FILES_API_HOST_PORT=127.0.0.1:18790

# ── noVNC (remote desktop into the gateway container) ───────
# Inside-container listener for websockify. The HOST's port binding
# (NOVNC_HOST_PORT above) controls actual reachability.
#   local = websockify binds 0.0.0.0 inside container (Docker port map decides)
#   off   = don't start noVNC
NOVNC_BIND=local

# VNC password. Auto-generated on first boot if left empty; value is saved to
# the gateway-state volume at /home/openclaw/.openclaw/.vnc-password.
VNC_PASSWORD=

# ── Gateway files-API (REQUIRED for the file browser) ────────
# Shared secret between the UI and the gateway. Generate one with:
#   openssl rand -hex 32
GATEWAY_AUTH_TOKEN=

# Where the UI reaches the gateway's files-API.
# Same-host Compose stack:  http://gateway:18790 (default, Docker DNS)
# Remote gateway over Tailscale: http://<gateway-host-ts-ip>:18790
GATEWAY_URL=http://gateway:18790

# Which interface the gateway binds the files-API to inside the container.
#   docker = Docker internal network only (default — UI reaches via "gateway" DNS)
#   any    = bind 0.0.0.0 inside container (host port mapping decides exposure)
#   off    = disable the file browser entirely
FILES_API_BIND=docker
FILES_API_PORT=18790

# ── Templates source (OPTIONAL) ──────────────────────────────
# Leave empty to use the templates bundled into the gateway image.
# Override with git+<url> to pull templates from your own repo, e.g.:
#   TEMPLATES_SOURCE=git+https://github.com/my-org/my-templates.git
TEMPLATES_SOURCE=

# ── Optional git remote for per-agent branches ───────────────
# If set, the gateway adds this as the `origin` remote of its local bare
# repo so per-agent changes can be pushed for backup/collaboration.
# Works for GitHub, Gitea, or any git host. Examples:
#   https://<token>@github.com/acme/hq-agents.git
#   git@github.com:acme/hq-agents.git   (requires GIT_DEPLOY_KEY)
GIT_REMOTE_URL=
# Paste the SSH private key (keep the surrounding double quotes so newlines
# are preserved). Leave empty for HTTPS remotes.
GIT_DEPLOY_KEY=

# ── GitHub sync (OPTIONAL, friendlier alternative to GIT_REMOTE_URL) ──
# If all three are set and GIT_REMOTE_URL is empty, the entrypoint
# constructs an HTTPS remote URL for you using the token. The gateway
# pushes every per-agent commit to this repo automatically.
#
# Token scope: fine-grained PAT with "Contents: Read and write" on the
# target repo. Classic PATs with `repo` scope also work.
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# ── Embeddings (OPTIONAL) ────────────────────────────────────
# The gateway-profile embedder uses FastEmbed locally and warms the model on
# boot. Leave defaults unless you are testing a different local model.
EMBEDDER_URL=http://embedder:18801
EMBEDDER_MODEL=BAAI/bge-small-en-v1.5
EMBEDDER_POLL_INTERVAL=10
EMBEDDER_BATCH_SIZE=8

# ── Tuning ───────────────────────────────────────────────────
POLL_INTERVAL=30
COMMAND_TIMEOUT=120
RECONCILE_INTERVAL=60
WAKE_COOLDOWN=30
# Git backup sweep — the runner's background thread that commits any
# uncommitted worktree changes and fast-forwards branches that moved on
# the remote. 0 disables the sweep (manual commits still work normally).
GIT_SYNC_INTERVAL=1800

# ── Image overrides (OPTIONAL) ───────────────────────────────
# Pin specific tags in production instead of :latest.
# UI_IMAGE=ghcr.io/yourhq/yourhq-ui:2026.04.20
# GATEWAY_IMAGE=ghcr.io/yourhq/yourhq-gateway:2026.04.20
# DISPATCHER_IMAGE=ghcr.io/yourhq/yourhq-dispatcher:2026.04.20
# RUNNER_IMAGE=ghcr.io/yourhq/yourhq-runner:2026.04.20
