# =============================================================================
# HQ — env file for the docker-compose stack.
#
# Copy to .env, fill in the values, then `docker compose up -d`.
# The install.sh script can do this interactively for you.
# =============================================================================

# ── Supabase (REQUIRED) ──────────────────────────────────────
# Create a free project at https://supabase.com. Copy the URL and keys from
# Project Settings → API. Run the migration at db/migrations/001_schema.sql
# in the SQL editor before first boot.
SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Gateway identity ─────────────────────────────────────────
# Unique per gateway within a Supabase project. Use different values when
# running multiple gateways against the same Supabase (e.g. "laptop",
# "mac-mini", "vps-eu").
GATEWAY_ID=default
GATEWAY_LABEL=Primary gateway

# Compose project name — namespaces volumes and containers. Change if you
# run multiple gateway stacks on the same host.
COMPOSE_PROJECT=yourhq

# Workspace slug — must match the slug you set in the HQ UI
# setup wizard. Agent branches are named "${WORKSPACE_SLUG}/${agent_slug}".
WORKSPACE_SLUG=my-workspace

# UI port on the host
UI_PORT=3000

# ── Tailscale (RECOMMENDED for remote desktop) ───────────────
# Generate a reusable auth key at:
#   https://login.tailscale.com/admin/settings/keys
# Leave empty to skip Tailscale entirely (noVNC will bind to localhost only).
TAILSCALE_AUTH_KEY=

# Optional: route the gateway's outbound traffic through a residential-IP
# exit node on your tailnet. Useful for sites that block datacenter IPs.
# Paste the Tailscale IP of the node, e.g. 100.64.0.5.
# https://tailscale.com/kb/1103/exit-nodes
TAILSCALE_EXIT_NODE=

# ── noVNC (remote desktop into the gateway container) ───────
# auto      = tailscale if TAILSCALE_AUTH_KEY is set, else local
# tailscale = bind to the container's tailnet IP only (recommended with TS)
# public    = bind 0.0.0.0, front with Caddy + Let's Encrypt (needs NOVNC_DOMAIN)
# local     = bind 127.0.0.1 only
# off       = don't start noVNC
NOVNC_BIND=auto

# Only used when NOVNC_BIND=public. Must point a DNS A/AAAA record at the host.
NOVNC_DOMAIN=
CADDY_EMAIL=

# VNC password. Auto-generated on first boot if left empty; value is saved to
# the gateway-state volume at /home/openclaw/.openclaw/.vnc-password.
VNC_PASSWORD=

# Host port mapping for noVNC. Default binds to localhost only (safe).
# Change to "0.0.0.0:6901" only when NOVNC_BIND=public.
NOVNC_HOST_PORT=127.0.0.1:6901

# ── Templates source (OPTIONAL) ──────────────────────────────
# Leave empty to use the templates bundled into the gateway image.
# Override with git+<url> to pull templates from your own repo, e.g.:
#   TEMPLATES_SOURCE=git+https://github.com/my-org/my-templates.git
TEMPLATES_SOURCE=

# ── Optional git remote for per-agent branches ───────────────
# If set, the gateway adds this as the `origin` remote of its local bare
# repo so per-agent changes can be pushed for backup/collaboration.
GIT_REMOTE_URL=
# Paste the SSH private key (keep the surrounding double quotes so newlines
# are preserved). Leave empty for HTTPS remotes.
GIT_DEPLOY_KEY=

# ── GitHub (OPTIONAL, for the UI's file browser with a GitHub remote) ──
# Not needed for self-hosted users using the local git repo.
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# ── Embeddings (OPTIONAL) ────────────────────────────────────
EMBEDDING_API_KEY=

# ── Tuning ───────────────────────────────────────────────────
POLL_INTERVAL=30
COMMAND_TIMEOUT=120
RECONCILE_INTERVAL=60
WAKE_COOLDOWN=30

# ── Image overrides (OPTIONAL) ───────────────────────────────
# Pin specific tags in production instead of :latest.
# UI_IMAGE=ghcr.io/yourhq/yourhq-ui:2026.04.20
# GATEWAY_IMAGE=ghcr.io/yourhq/yourhq-gateway:2026.04.20
# DISPATCHER_IMAGE=ghcr.io/yourhq/yourhq-dispatcher:2026.04.20
# RUNNER_IMAGE=ghcr.io/yourhq/yourhq-runner:2026.04.20
