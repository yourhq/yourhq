{
  "name": "@yourhq/e2e",
  "private": true,
  "scripts": {
    "test": "playwright test --project=setup --project=chromium",
    "test:smoke": "playwright test --grep @smoke --project=setup --project=chromium",
    "test:live": "E2E_LIVE=1 playwright test --project=setup --project=live",
    "test:all": "E2E_LIVE=1 playwright test",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@supabase/supabase-js": "^2.49.0",
    "dotenv": "^16.4.0"
  }
}
