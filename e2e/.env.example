# HQ E2E Test Configuration
# Copy to .env and fill in real values. Never commit .env.

# Target HQ instance
E2E_BASE_URL=http://localhost:3000

# Supabase (same project the HQ instance connects to)
E2E_SUPABASE_URL=https://your-project.supabase.co
E2E_SUPABASE_ANON_KEY=eyJ...
E2E_SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Model providers (for provider + budget specs)
E2E_OPENAI_API_KEY=sk-...
E2E_ANTHROPIC_API_KEY=sk-ant-...

# Telegram (for channel pairing spec — optional, skipped if empty)
E2E_TELEGRAM_BOT_TOKEN=

# SSH access for infra checks (optional, skipped if empty)
E2E_SSH_HOST=
E2E_SSH_KEY_PATH=
E2E_SSH_USER=ubuntu

# Test account credentials (created during onboarding spec)
E2E_USER_EMAIL=e2e-test@yourhq.ai
E2E_USER_PASSWORD=TestPass123!
