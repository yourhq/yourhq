# =============================================================================
# HQ — Hosted deployment (.env for `docker compose --profile hosted up`)
#
# Copy to .env, fill in the values, then:
#   docker compose --profile hosted up -d
#
# This starts the UI + worker. Gateways run on E2B (not locally).
# =============================================================================

# ── Deployment mode ──────────────────────────────────────────
DEPLOYMENT_MODE=hosted

# ── Public URL ───────────────────────────────────────────────
# Where the hosted UI is reachable. Used for auth redirects, magic link
# callbacks, and provisioning emails.
PUBLIC_SITE_URL=https://yourhq.ai

# ── Master Supabase (accounts database) ─────────────────────
# A dedicated Supabase project that stores hosted_users,
# hosted_workspaces, and sandbox_events.
MASTER_SUPABASE_URL=
MASTER_SUPABASE_SERVICE_ROLE_KEY=

# ── Supabase Management API ─────────────────────────────────
# Used to create and destroy per-tenant Supabase projects.
# Generate at: https://supabase.com/dashboard/account/tokens
SUPABASE_MANAGEMENT_API_TOKEN=
SUPABASE_ORG_ID=
SUPABASE_REGION=us-east-1

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=


# ── Resend (transactional email) ────────────────────────────
RESEND_API_KEY=
# From address for provisioning and auth emails.
EMAIL_FROM=HQ <hello@yourhq.ai>
EMAIL_REPLY_TO

# ── PostHog (product analytics) ─────────────────────────────
# Only used in hosted mode. Self-hosted never loads the SDK.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=

# ── Sentry (error tracking) ─────────────────────────────────
# Only used in hosted mode. Self-hosted never loads the SDK.
# NEXT_PUBLIC_SENTRY_DSN is used by the UI (client + server).
# SENTRY_DSN is used by the worker and passed to E2B gateway sandboxes.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# ── E2B (sandbox runtime) ───────────────────────────────────
# Each workspace gets a dedicated E2B sandbox running the gateway.
E2B_API_KEY=
E2B_TEMPLATE_NAME=yourhq-gateway

# ── Notion OAuth (source connections) ────────────────────────
# Create a public integration at https://www.notion.so/my-integrations
# Set the redirect URI to: ${PUBLIC_SITE_URL}/api/sources/oauth/notion/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# ── Internal auth ────────────────────────────────────────────
# Shared secret between the UI and the worker. Generate with:
#   openssl rand -hex 32
WORKER_INTERNAL_TOKEN=

# Encrypts tenant service role keys, database passwords, and VNC passwords
# before storage in the master Supabase project. Generate with:
#   openssl rand -base64 32
HOSTED_SECRETS_KEY=

# ── Worker ───────────────────────────────────────────────────
# URL where the UI reaches the worker.
# Docker Compose: http://worker:3001 (internal DNS)
# Vercel + ECS Express: https://worker.yourhq.ai
WORKER_URL=http://worker:3001

# ── UI ───────────────────────────────────────────────────────
# Host port binding for the UI. Default is loopback-only.
# Ignored when deploying to Vercel.
UI_HOST_PORT=0.0.0.0:3000

# Host port binding for the worker (Stripe webhooks need to reach this).
# Ignored when deploying to ECS Express.
WORKER_HOST_PORT=0.0.0.0:3001

# ── Compose ──────────────────────────────────────────────────
COMPOSE_PROJECT=yourhq
